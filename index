  S.running=false;S.t=0;S.atpHistory=[];S.particles=[];
  S.outputs={atp:0,nadph:0,o2:0,grad:0};
  btnStart.textContent='▶ Start';
  document.getElementById('status-dot').className='';
  document.getElementById('status-label').textContent='IDLE';
  const g=getGeo(S.simWidth,S.simHeight);
  drawSim({psii:0,pq:0,cytb:0,psi:0,nadph:0,atp:0,o2:0,grad:0,lim:{name:'—'}},S.params);
  drawGraph();
  updateOutputs({psii:0,pq:0,cytb:0,psi:0,nadph:0,atp:0,o2:0,grad:0,lim:{name:'—'}});
});

// ── Tooltip ────────────────────────────────────────────────────────────────
function showTooltip(comp,mx,my){
  ttTitle.textContent=comp.title;
  ttBody.textContent=comp.body;
  tooltip.style.display='block';
  let lx=mx+14,ty=my-10;
  if(lx+230>window.innerWidth) lx=mx-244;
  if(ty+120>window.innerHeight) ty=my-120;
  tooltip.style.left=lx+'px';tooltip.style.top=ty+'px';
}
function hideTooltip(){ tooltip.style.display='none'; }

simCanvas.addEventListener('mousemove',e=>{
  const rect=simCanvas.getBoundingClientRect();
  const sx=(e.clientX-rect.left);
  const sy=(e.clientY-rect.top);
  let hit=null;
  for(const c of S.components){
    if(sx>=c.x&&sx<=c.x+c.w&&sy>=c.y&&sy<=c.y+c.h){hit=c;break;}
  }
  if(hit) showTooltip(hit,e.clientX,e.clientY);
  else hideTooltip();
});
simCanvas.addEventListener('mouseleave',hideTooltip);

// touch tooltip
simCanvas.addEventListener('touchstart',e=>{
  const touch=e.touches[0];
  const rect=simCanvas.getBoundingClientRect();
  const sx=touch.clientX-rect.left,sy=touch.clientY-rect.top;
  let hit=null;
  for(const c of S.components){
    if(sx>=c.x&&sx<=c.x+c.w&&sy>=c.y&&sy<=c.y+c.h){hit=c;break;}
  }
  if(hit){showTooltip(hit,touch.clientX,touch.clientY);e.preventDefault();}
  else hideTooltip();
},{passive:false});

// ── Guided prompts ─────────────────────────────────────────────────────────
const promptConfigs=[
  {light:2000,wave:680,temp:25,h2o:100,nadp:30,adp:80,dcmu:0},
  {light:2000,wave:680,temp:25,h2o:100,nadp:20,adp:20,dcmu:0},
  {light:600,wave:680,temp:25,h2o:100,nadp:5,adp:80,dcmu:0},
];
window.sendPrompt=function(i){
  const cfg=promptConfigs[i];
  Object.assign(S.params,cfg);
  sliders.forEach(([slId,vId,key])=>{
    if(cfg[key]!==undefined){
      document.getElementById(slId).value=cfg[key];
      document.getElementById(vId).textContent=cfg[key];
    }
  });
  updateWaveUI(S.params.wave);
  S.dirty=true;
  if(!S.running){ S.running=true; btnStart.textContent='⏸ Pause'; S.lastTime=performance.now(); if(!S.raf) S.raf=requestAnimationFrame(loop); }
};

// ── Start idle render ─────────────────────────────────────────────────────
setTimeout(()=>{
  resizeCanvases();
  const g=getGeo(S.simWidth,S.simHeight);
  drawSim({psii:0,pq:0,cytb:0,psi:0,nadph:0,atp:0,o2:0,grad:0,lim:{name:'—'}},S.params);
  S.raf=requestAnimationFrame(loop);
},200);

})();
