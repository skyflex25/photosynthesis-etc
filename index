btnStart.addEventListener('click',()=>{
  S.running=!S.running;
  btnStart.textContent=S.running?'⏸ Pause':'▶ Start';
  if(S.running&&!S.raf){S.lastTime=performance.now();S.raf=requestAnimationFrame(loop);}
});
